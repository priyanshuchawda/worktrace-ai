# WorkTrace AI environment template.
# Copy to .env for local development. Keep real secrets out of git.

# Local sidecar server. Only localhost/127.0.0.1 are valid.
WORKTRACE_SIDECAR_HOST=127.0.0.1
WORKTRACE_SIDECAR_PORT=8765

# Optional local database override.
# WORKTRACE_DB_PATH=C:\Users\<you>\.worktrace\db\worktrace.sqlite

# Optional local model/artifact cache override.
# WORKTRACE_MODEL_CACHE=C:\Users\<you>\.worktrace\models

# Optional local-only runtime endpoints and paths.
# These are skip-safe unless explicitly configured.
# WORKTRACE_QWEN_EMBEDDING_BASE_URL=http://127.0.0.1:8001
# WORKTRACE_QWEN_VL_BASE_URL=http://127.0.0.1:8002
# WORKTRACE_FASTER_WHISPER_MODEL_PATH=C:\models\faster-whisper-base
# WORKTRACE_FASTER_WHISPER_SAMPLE_AUDIO_PATH=C:\path\to\sample.wav

# AI report provider selection.
# Current development default uses Gemini API-hosted Gemma for reports only.
# Product direction remains local-first; gemini_gemma_dev is development-only.
WORKTRACE_AI_PROVIDER=gemini_gemma_dev
WORKTRACE_ENABLE_DEV_CLOUD_AI=true
WORKTRACE_LOCAL_OLLAMA_BASE_URL=http://127.0.0.1:11434

# Development-only hosted Gemma provider.
# Set GEMINI_API_KEY only in your private .env or shell environment.
# The sidecar entrypoint loads a local .env without printing or committing it.
# GEMINI_API_KEY=your-google-ai-studio-api-key
WORKTRACE_GEMMA_PRIMARY_MODEL=gemma-4-31b-it
WORKTRACE_GEMMA_FALLBACK_MODEL=gemma-4-26b-a4b-it
